{
  "name": "@likhinmn/raxios",
  "version": "0.2.0",
  "description": "Axios-like HTTP client for Node.js backed by Rust reqwest via NAPI-RS",
  "keywords": [
    "http",
    "client",
    "axios",
    "reqwest",
    "napi-rs",
    "rust"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LikhinMN/raxios.git"
  },
  "main": "raxios.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^1.6.0"
  },
  "napi": {
    "name": "raxios",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin"
      ]
    }
  }
}
